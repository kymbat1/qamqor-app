APP_NAME=Qamqor API
ENVIRONMENT=development
API_PREFIX=/api/v1

# PostgreSQL installed locally with pgAdmin.
# Prefer separate fields: passwords with @ # % / : do not need URL encoding here.
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=qamqor
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_postgres_password

# Alternative advanced form. If you use this and the password has special
# characters, URL-encode it first.
# DATABASE_URL=postgresql+asyncpg://postgres:your_postgres_password@127.0.0.1:5432/qamqor

# Change this before real deployment.
JWT_SECRET_KEY=change_me_to_a_long_random_secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# First admin user created by scripts/seed.py
ADMIN_EMAIL=admin@qamqor.kz
ADMIN_PASSWORD=admin12345
ADMIN_NAME=Qamqor Admin

# Demo doctor accounts created by scripts/init_db.py
DOCTOR_PASSWORD=doctor12345

# Email verification for registration.
# debug prints the code in backend logs and returns it to the app for local testing.
# smtp sends a real email through your provider.
EMAIL_DELIVERY_MODE=debug
VERIFICATION_CODE_TTL_MINUTES=10
VERIFICATION_CODE_RESEND_SECONDS=60
VERIFICATION_CODE_MAX_ATTEMPTS=5
VERIFICATION_CODE_MAX_SENDS=5

# Required only when EMAIL_DELIVERY_MODE=smtp.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=your_smtp_username
SMTP_PASSWORD=your_smtp_password
SMTP_FROM_EMAIL=noreply@qamqor.kz
SMTP_USE_TLS=true

# Local AI assistant. Install Ollama locally and run:
# ollama pull llama3.2:3b
# ollama serve
AI_PROVIDER=local
AI_LOCAL_BASE_URL=http://127.0.0.1:11434
AI_LOCAL_MODEL=llama3.2:3b
AI_LOCAL_FORMAT=ollama
AI_TIMEOUT_SECONDS=45
AI_ALLOW_FALLBACK=true
