# Python/FastAPI backend.
# Web/Windows desktop: http://127.0.0.1:8000/api/v1
# Android emulator: http://10.0.2.2:8000/api/v1
BACKEND_API_URL=http://127.0.0.1:8000/api/v1
API_BASE_URL=http://127.0.0.1:8000/api/v1

# debug returns the OTP code to the app for local testing.
# http sends POST /otp/send to your backend, which should call Email/WhatsApp providers.
OTP_DELIVERY_MODE=debug
OTP_API_BASE_URL=https://your-auth-backend.example.com
OTP_API_KEY=optional_backend_api_key

# Grok/xAI assistant. For production, call Grok through your FastAPI backend,
# not directly from the Flutter client.
XAI_API_KEY=your_xai_api_key_here
XAI_MODEL=grok-3-mini
XAI_API_BASE_URL=https://api.x.ai/v1
